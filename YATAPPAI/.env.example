# Backend API URL - Beckend API (port 3002)
# 1. Start the Beckend server on port 3002
# 2. Set URL based on where you run the app:
#    - Web / iOS simulator: http://localhost:3002/api
#    - Android emulator:     http://10.0.2.2:3002/api
#    - Physical device:     http://YOUR_COMPUTER_IP:3002/api
# 3. Restart Expo after changing: npx expo start --clear
EXPO_PUBLIC_API_URL=http://localhost:3002/api
